# =============================================================
# Dev Portfolio — Environment Variables
# =============================================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored — never commit real credentials.
# This file is the reference for what variables are required.

# ── PostgreSQL ────────────────────────────────────────────────
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=portfolio_db
DB_HOST=dashboard_db

# ── Oracle XE ────────────────────────────────────────────────
ORACLE_PASSWORD=your_oracle_password
ORACLE_XE_DB=XEPDB1

# ── MongoDB (Analytics) ───────────────────────────────────────
MONGO_USER=admin
MONGO_PASSWORD=your_mongo_password
MONGO_DB=portfolio_analytics

# ── FastAPI ───────────────────────────────────────────────────
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:5432/${DB_NAME}
SECRET_KEY=your_secret_key_minimum_32_characters_long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── LLM / Auth ────────────────────────────────────────────────
# Get your Gemini API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
JWT_SECRET=your_jwt_secret_change_in_production

# ── AWS ───────────────────────────────────────────────────────
LAMBDA_URL=https://your-api-gateway-url/default/your-lambda-function
